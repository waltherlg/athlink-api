// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(uuid()) @db.Uuid
  userName     String @unique
  email        String @unique @db.VarChar(255)
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isConfirmed           Boolean   @default(false)
  confirmationCode      String?   @db.Uuid
  confirmCodeExpiryDate DateTime?

  passwordRecoveryCode      String?   @db.Uuid
  passwordRecoveryExpiresAt DateTime?

  // logs
  trainingJournals TrainingJournal[]
  journalAccesses  JournalAccess[]
  sessions         Session[]
}

model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String

  ip        String
  userAgent String

  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
}

model TrainingJournal {
  id String @id @default(uuid()) @db.Uuid

  athleteId String @db.Uuid
  athlete   User   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  sportType SportType

  trainingRecords TrainingRecord[]

  accesses JournalAccess[]

  createdAt DateTime @default(now())

  @@unique([athleteId, sportType])
}

model JournalAccess {
  id String @id @default(uuid()) @db.Uuid

  userId    String @db.Uuid
  journalId String @db.Uuid

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  journal TrainingJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  role AccessRole

  createdAt      DateTime @default(now())
  coachAthleteId String?

  @@unique([userId, journalId])
}

enum AccessRole {
  COACH
}

enum SportType {
  SHOOTING
}

model TrainingRecord {
  id String @id @default(uuid()) @db.Uuid

  trainingJournalId String          @db.Uuid
  trainingJournal   TrainingJournal @relation(fields: [trainingJournalId], references: [id], onDelete: Cascade)

  result       String?
  coachNotes   String?
  privateNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
