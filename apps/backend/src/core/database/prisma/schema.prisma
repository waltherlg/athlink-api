// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(uuid()) @db.Uuid
  userName     String @unique
  email        String @unique @db.VarChar(255)
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isConfirmed           Boolean   @default(false)
  confirmationCode      String?   @db.Uuid
  confirmCodeExpiryDate DateTime?

  passwordRecoveryCode      String?   @db.Uuid
  passwordRecoveryExpiresAt DateTime?

  // logs
  trainingJournals TrainingJournal[]
  sessions         Session[]
  coachProfiles    CoachProfile[]
}

model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String

  ip        String
  userAgent String

  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
}

model TrainingJournal {
  id String @id @default(uuid()) @db.Uuid

  athleteId String @db.Uuid
  athlete   User   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  sportType SportType

  records TrainingRecord[]

  accesses JournalAccess[]

  createdAt DateTime @default(now())

  accessRequests AccessRequest[]

  @@unique([athleteId, sportType])
}

model JournalAccess {
  id String @id @default(uuid()) @db.Uuid

  coachProfileId String @db.Uuid
  journalId      String @db.Uuid

  coachProfile CoachProfile    @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  journal      TrainingJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  role AccessRole

  createdAt DateTime @default(now())

  @@unique([coachProfileId, journalId])
}

enum AccessRole {
  COACH
}

enum SportType {
  SHOOTING_RIFLE_PISTOL
}

model TrainingRecord {
  id String @id @default(uuid()) @db.Uuid

  journalId String          @db.Uuid
  journal   TrainingJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  type TrainingRecordType

  eventId String?     @db.Uuid
  event   SportEvent? @relation(fields: [eventId], references: [id])

  result       Float?
  coachNotes   String?
  privateNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SportEvent {
  id String @id @default(uuid()) @db.Uuid

  sportType SportType

  code String
  name String

  resultType ResultType

  maxScore Float?
  decimals Int?

  createdAt DateTime @default(now())

  records TrainingRecord[]

  @@unique([sportType, code])
}

model CoachProfile {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  sportType SportType

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessRequests  AccessRequest[]
  journalAccesses JournalAccess[]

  @@unique([userId, sportType])
}

model AccessRequest {
  id String @id @default(uuid()) @db.Uuid

  journalId      String @db.Uuid
  coachProfileId String @db.Uuid

  status RequestStatus @default(PENDING)

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  journal      TrainingJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  coachProfile CoachProfile    @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ResultType {
  SCORE
  TIME
  DISTANCE
}

enum TrainingRecordType {
  STRUCTURED
  FREE
}
