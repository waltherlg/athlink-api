// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(uuid())
  userName     String @unique
  email        String @unique @db.VarChar(255)
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // logs
  trainingJournals TrainingJournal[]
  journalAccesses  JournalAccess[]
}

model TrainingJournal {
  id String @id @default(uuid())

  athleteId String
  athlete   User   @relation(fields: [athleteId], references: [id])

  sportType SportType @unique

  trainingRecords TrainingRecord[]

  accesses JournalAccess[]

  createdAt DateTime @default(now())
}

model JournalAccess {
  id String @id @default(uuid())

  userId    String
  journalId String

  user    User            @relation(fields: [userId], references: [id])
  journal TrainingJournal @relation(fields: [journalId], references: [id])

  role AccessRole

  createdAt      DateTime @default(now())
  coachAthleteId String?

  @@unique([userId, journalId])
}

enum AccessRole {
  COACH
}

enum SportType {
  SHOOTING
}

model TrainingRecord {
  id String @id @default(uuid())

  trainingJournalId String
  trainingJournal   TrainingJournal @relation(fields: [trainingJournalId], references: [id])

  result       String?
  coachNotes   String?
  privateNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
