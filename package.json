{
  "name": "athlink-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:dev": "pnpm -C apps/backend start:dev",
    "build": "pnpm -C apps/backend build",
    "format": "pnpm -C apps/backend format",
    "start": "pnpm -C apps/backend start",
    "start:debug": "pnpm -C apps/backend start:debug",
    "start:prod": "pnpm -C apps/backend start:prod",
    "prisma-generate": "pnpm -C apps/backend prisma-generate",
    "prisma-migrate: create only": "pnpm -C apps/backend run \"prisma-migrate: create only\"",
    "prisma-migrate-deploy": "pnpm -C apps/backend prisma-migrate-deploy",
    "lint": "pnpm -C apps/backend lint",
    "test": "pnpm -C apps/backend test",
    "test:watch": "pnpm -C apps/backend test:watch",
    "test:cov": "pnpm -C apps/backend test:cov",
    "test:debug": "pnpm -C apps/backend test:debug",
    "test:e2e": "pnpm -C apps/backend test:e2e",
    "frontend:dev": "pnpm -C apps/frontend dev",
    "frontend:build": "pnpm -C apps/frontend build",
    "frontend:preview": "pnpm -C apps/frontend preview"
  },
  "dependencies": {
    "-": "^0.0.1",
    "typescript": "^5.9.3"
  }
}
